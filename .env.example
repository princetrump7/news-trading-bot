# === Your Telegram config ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# === LLM API (OpenAI-compatible) ===
# OpenRouter:     https://openrouter.ai/api/v1  (get key at https://openrouter.ai/keys)
# OpenAI:         https://api.openai.com/v1
# Any other OpenAI-compatible endpoint
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# OpenRouter identity (optional — shows in OpenRouter dashboard)
OPENROUTER_REFERER=https://github.com/princ/news-trading-bot
OPENROUTER_TITLE=News Trading Bot
